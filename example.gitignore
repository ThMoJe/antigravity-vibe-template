# ========================================
# Antigravity 2.0 Monorepo .gitignore
# Optimized for Vibe Coding workflows
# ========================================

# ========================================
# AI AGENT ARTIFACTS (Vibe Coding)
# ========================================
# Antigravity/Gemini agent brain state (conversation-specific)
.gemini/
.antigravitycli/

# Agent workflow files are allowed in .agent/
!.agent/

# Local AI experimentation (ephemeral)
.ai-scratch/
*.ai-draft.md

# Generated by consolidate_docs.ps1
consolidated_docs.md

# ========================================
# DEPENDENCIES
# ========================================
node_modules/
.pnp
.pnp.js
.yarn/

# ========================================
# ENVIRONMENT VARIABLES & SECRETS
# ========================================
# Ignore the base .env (contains secrets)
.env

# Ignore local override files
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Allow committed mode-based env files (contain only URLs, no secrets)
!.env.development
!.env.android
!.env.test
!.env.production
!.env.example
!.env.sample

# ========================================
# EDITOR CONFIGURATION
# ========================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace

# JetBrains
.idea/
*.iml

# ========================================
# BUILD OUTPUT & ARTIFACTS
# ========================================
dist/
dev-dist/
build/
.vite/
*.tsbuildinfo
.eslintcache

# ========================================
# TYPESCRIPT & ESM
# ========================================
*.js.map

# ========================================
# LOGS & DEBUGGING
# ========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Application logs
logs/
*.log

# ========================================
# DATABASE BACKUPS
# ========================================
backups/*
!backups/.gitkeep

# ========================================
# OS & SYSTEM
# ========================================
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ========================================
# TEMPORARY FILES
# ========================================
tmp/
temp/
.tmp/

# ========================================
# TESTING
# ========================================
coverage/
.nyc_output/
*.lcov

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# ========================================
# SECRETS & CREDENTIALS
# ========================================
*.pem
*.key
*.crt
*.p12
*.pfx
*-credentials.json
*-service-account.json

# ========================================
# MOBILE (Capacitor/Android)
# ========================================
**/local.properties

# ========================================
# PROMOTION & MARKETING ARTIFACTS
# ========================================
_promotion/

